---
import Barebone from "@/layouts/Barebone.astro";
import Header from "@/components/layout/LayoutHeader.astro";
import Footer from "@/components/layout/LayoutFooter.astro";

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}
---

<Barebone {...Astro.props}>
  <Header />

  <main class="bg-white-sakura mx-auto max-w-480 bg-white">
    <slot />
  </main>

  <Footer />
</Barebone>
