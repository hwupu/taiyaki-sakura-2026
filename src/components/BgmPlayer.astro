---

---

<div
  id="bgm-player"
  class="flex h-(--header-height) w-16 flex-col items-center"
>
  <audio id="bgm" loop preload="auto">
    <source src="/bgm/docchi.opus" type="audio/ogg; codecs=opus" />
  </audio>
  <button
    id="bgm-toggle"
    aria-label="Toggle music"
    class="flex w-16 flex-col items-center gap-1 border-0 bg-transparent p-0 pt-3"
  >
    <div
      id="bgm-icon"
      class="grid size-16 flex-none place-items-center bg-amber-200 text-5xl"
    >
      🔊
    </div>
    <div class="text-sakura-900 text-md text-center font-semibold">BGM</div>
  </button>
  <input
    id="bgm-volume"
    type="range"
    min="0"
    max="1"
    step="0.05"
    value="0.5"
    aria-label="Volume"
    class="accent-sakura-400 hidden w-20"
  />
</div>

<script>
  const audio = document.getElementById("bgm") as HTMLAudioElement;
  const toggle = document.getElementById("bgm-toggle") as HTMLButtonElement;
  const slider = document.getElementById("bgm-volume") as HTMLInputElement;
  const icon = document.getElementById("bgm-icon") as HTMLInputElement;

  audio.volume = 0.5;

  function setIcon() {
    if (audio.muted || audio.volume === 0) {
      icon.textContent = "🔇";
    } else {
      icon.textContent = "🔊";
    }
  }

  // Autoplay — browsers may block it until first interaction
  audio.play().catch(() => {
    icon.textContent = "▶️";
    document.addEventListener(
      "click",
      () => {
        audio.play().then(setIcon);
      },
      { once: true },
    );
  });

  toggle.addEventListener("click", (e) => {
    e.stopPropagation();
    if (audio.paused) {
      audio.play().then(setIcon);
    } else {
      audio.muted = !audio.muted;
      setIcon();
    }
  });

  slider.addEventListener("input", () => {
    audio.volume = parseFloat(slider.value);
    if (audio.muted && audio.volume > 0) audio.muted = false;
    setIcon();
  });
</script>
