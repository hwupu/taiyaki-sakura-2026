---

---

<div
  id="bgm-player"
  class="fixed right-4 bottom-4 flex items-center gap-2 rounded-full bg-sakura-50/85 px-3 py-2 shadow-[0_2px_8px_rgba(0,0,0,0.12)] backdrop-blur-[6px]"
>
  <audio id="bgm" loop preload="auto">
    <source src="/bgm/docchi.opus" type="audio/ogg; codecs=opus" />
  </audio>
  <button
    id="bgm-toggle"
    aria-label="Toggle music"
    class="border-0 bg-transparent p-0 text-xl leading-none"
    >🔊</button
  >
  <input
    id="bgm-volume"
    type="range"
    min="0"
    max="1"
    step="0.05"
    value="0.5"
    aria-label="Volume"
    class="w-20 accent-sakura-400"
  />
</div>

<script>
  const audio = document.getElementById("bgm") as HTMLAudioElement;
  const toggle = document.getElementById("bgm-toggle") as HTMLButtonElement;
  const slider = document.getElementById("bgm-volume") as HTMLInputElement;

  audio.volume = 0.5;

  function setIcon() {
    if (audio.muted || audio.volume === 0) {
      toggle.textContent = "🔇";
    } else {
      toggle.textContent = "🔊";
    }
  }

  // Autoplay — browsers may block it until first interaction
  audio.play().catch(() => {
    toggle.textContent = "▶️";
    document.addEventListener(
      "click",
      () => {
        audio.play().then(setIcon);
      },
      { once: true },
    );
  });

  toggle.addEventListener("click", (e) => {
    e.stopPropagation();
    if (audio.paused) {
      audio.play().then(setIcon);
    } else {
      audio.muted = !audio.muted;
      setIcon();
    }
  });

  slider.addEventListener("input", () => {
    audio.volume = parseFloat(slider.value);
    if (audio.muted && audio.volume > 0) audio.muted = false;
    setIcon();
  });
</script>
