---
import { getRelativeLocaleUrl } from "astro:i18n";

import BgmPlayer from "@/components/BgmPlayer.astro";
import iconGlobus from "@/icons/solar/solar--globus-bold.svg?raw";
import iconCamera from "@/icons/solar/solar--camera-bold.svg?raw";
import iconTaiyaki from "@/icons/icon-taiyaki.svg?raw";
import iconArrowDown from "@/icons/solar/solar--arrow-down-linear.svg?raw";

const lang = Astro.currentLocale === "zh-TW" ? "zh-TW" : "en";

const rawPath = Astro.url.pathname.startsWith("/zh")
  ? Astro.url.pathname.slice(3) || "/"
  : Astro.url.pathname;
const enUrl = getRelativeLocaleUrl("en", rawPath);
const zhUrl = getRelativeLocaleUrl("zh-TW", rawPath);
---

<header
  class="sticky top-0 z-20 -mt-[calc(var(--header-height)+env(safe-area-inset-bottom)+var(--header-margin)+0.5rem)] h-[calc(var(--header-height)+env(safe-area-inset-bottom)+var(--header-margin)+0.5rem)]"
>
  <div
    class="sticky top-2 flex h-(--header-height) justify-center md:mx-auto md:w-fit md:max-w-480 md:gap-10 md:rounded-xl md:bg-white/50 md:px-10 md:shadow md:backdrop-blur-sm"
  >
    <!-- Home -->
    <a
      href={getRelativeLocaleUrl(lang, "/")}
      class="text-sakura-900 hover:text-sakura-400 hidden h-(--header-height) w-16 flex-col items-center pt-2 md:flex"
    >
      <div class="grid size-16 flex-none place-items-center">
        <span class="block size-14" set:html={iconTaiyaki} />
      </div>
      <div class="text-md text-center font-semibold">
        {lang === "zh-TW" ? "首頁" : "Home"}
      </div>
    </a>

    <!-- Gallery -->
    <a
      href={getRelativeLocaleUrl(lang, "/gallery")}
      class="text-sakura-900 hover:text-sakura-400 hidden h-(--header-height) w-16 flex-col items-center pt-2 md:flex"
    >
      <div class="grid size-16 flex-none place-items-center">
        <span class="block size-14" set:html={iconCamera} />
      </div>
      <div class="text-md text-center font-semibold">
        {lang === "zh-TW" ? "回憶" : "Memories"}
      </div>
    </a>

    <div
      class="pointer-events-none sticky top-0 -mt-[calc(50svh-var(--header-height)-var(--header-margin)+0.5rem)] h-[calc(50svh-var(--header-margin)+0.5rem)]"
      aria-hidden="true"
    >
      <div class="sticky top-0 h-(--header-height) flex-none">
        <picture>
          <source srcset="/images/type-logo-sakura@3x.avif" type="image/avif" />
          <source srcset="/images/type-logo-sakura@3x.webp" type="image/webp" />
          <img
            src="/images/type-logo-sakura@3x.png"
            alt="Taiyaki Sakura"
            width="280"
            class="pointer-events-none max-w-[min(280px,70vw)] translate-x-2 -translate-y-2"
          />
        </picture>
      </div>
      <div
        class="pointer-event-none absolute inset-x-0 bottom-0 -z-10 grid h-(--header-height) items-end justify-center p-2"
      >
        <span
          class="text-sakura-200 md:text-sakura-100 block size-12 animate-bounce"
          set:html={iconArrowDown}
        />
      </div>
    </div>

    <!-- Language switcher -->
    <a
      href={lang === "zh-TW" ? enUrl : zhUrl}
      class="text-sakura-900 hover:text-sakura-400 hidden h-(--header-height) w-16 flex-col items-center pt-2 md:flex"
    >
      <div class="grid size-16 flex-none place-items-center text-5xl">
        <span class="block size-14" set:html={iconGlobus} />
      </div>
      <div class="text-md text-center font-semibold">
        {lang === "zh-TW" ? "English" : "中文"}
      </div>
    </a>

    <BgmPlayer />
  </div>
</header>
