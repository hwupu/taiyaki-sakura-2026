---
import logoRaw from "@/icons/logo.svg?raw";

const lang = Astro.currentLocale === "zh-TW" ? "zh-TW" : "en";
const t = {
  en: { rights: ". All rights reserved." },
  "zh-TW": { rights: " 版權所有。" },
}[lang];
---

<footer class="text-sakura-900 relative isolate mx-auto max-w-480 bg-white p-6">
  <p class="text-sm">
    &copy; {new Date().getFullYear()}
    <a
      href="https://phwu.dev"
      class="no-outline uppercase"
      target="_blank"
      rel="noopener noreferrer">phwu</a
    >{t.rights}
  </p>
  <a
    href="https://phwu.dev"
    class="text-sakura-900 absolute right-4 bottom-4"
    target="_blank"
    rel="noopener noreferrer"
  >
    <span class="sr-only">phwu.dev</span>
    <span class="pointer-events-none block size-8" set:html={logoRaw} />
  </a>
</footer>
