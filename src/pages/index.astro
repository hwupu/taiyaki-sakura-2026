---
import BaseLayout from "../layouts/BaseLayout.astro";
import BgmPlayer from "../components/BgmPlayer.astro";
---

<BaseLayout title="Taiyaki Sakura — Minecraft Server" hideNav>
  <div class="flex min-h-screen items-center justify-center">
    <picture>
      <source srcset="/images/taiyaki-type-ring@3x.avif" type="image/avif" />
      <source srcset="/images/taiyaki-type-ring@3x.webp" type="image/webp" />
      <img
        src="/images/taiyaki-type-ring@3x.png"
        alt="Taiyaki Sakura"
        width="320"
        class="max-w-[min(320px,80vw)]"
      />
    </picture>
  </div>
  <BgmPlayer />
</BaseLayout>
