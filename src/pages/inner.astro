---
import BaseLayout from "@/layouts/BaseLayout.astro";
import GalleryModal from "@/components/gallery/GalleryModal.astro";
import type { GalleryImage } from "@/components/gallery/GalleryModal.astro";

const CDN = "https://cdn.phwu.work";

const screenshots: GalleryImage[] = [
  {
    src: `${CDN}/gallery/2023-06-30_17.28.01`,
    alt: "Spawn area",
    caption: "The main spawn",
  },
  {
    src: `${CDN}/gallery/2023-06-30_17.28.01`,
    alt: "Farm district",
  },
  {
    src: `${CDN}/gallery/2023-06-30_17.28.01`,
    alt: "Player build showcase",
    caption: "Built in survival mode",
  },
];
---

<BaseLayout title="Gallery — Taiyaki Sakura">
  <div class="mx-auto max-w-4xl px-4 py-12">
    <h1 class="text-sakura-900 mb-8 text-3xl font-bold">Gallery</h1>
    <GalleryModal images={screenshots} columns={3} />
  </div>
  <GalleryModal images={screenshots} layout="strip" />
</BaseLayout>
