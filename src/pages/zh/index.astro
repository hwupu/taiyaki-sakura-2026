---
import Barebone from "@/layouts/Barebone.astro";
import Header from "@/components/layout/LayoutHeader.astro";
import Footer from "@/components/layout/LayoutFooter.astro";

import HowTo from "@/components/howto/HowToZhV1.astro";
---

<Barebone title="Taiyaki Sakura">
  <aside
    class="bg-sakura-50 mx-auto flex h-[calc(100vh-env(safe-area-inset-bottom))] max-h-180 max-w-480 items-center justify-center"
  >
    <picture>
      <source srcset="/images/taiyaki-type-ring@3x.avif" type="image/avif" />
      <source srcset="/images/taiyaki-type-ring@3x.webp" type="image/webp" />
      <img
        src="/images/taiyaki-type-ring@3x.png"
        alt="Taiyaki Sakura"
        width="320"
        class="pointer-events-none max-w-[min(320px,80vw)]"
      />
    </picture>
  </aside>
  <Header />
  <main class="bg-white-sakura mx-auto max-w-480 bg-white py-10">
    <HowTo />
  </main>

  <Footer />
</Barebone>
